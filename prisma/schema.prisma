// Summer Strikes — Prisma schema
// Postgres in prod (Neon via Vercel Postgres); set DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  PARENT
  ADMIN
  STAFF
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?
  firstName           String
  lastName            String
  address             String
  city                String
  state               String
  zip                 String
  phone               String?
  smsOptIn            Boolean   @default(false)
  smsConsentAt        DateTime?
  smsConsentIp        String?
  termsAcceptedAt     DateTime
  role                Role      @default(PARENT)
  reservationCode     String?   @unique @db.VarChar(8)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  children            Child[]
  adults              Adult[]
  vouchers            Voucher[]
  pendingAdults       PendingAdult[]
  sessions            Session[]
  accounts            Account[]

  @@index([phone])
  @@index([role])
}

model Child {
  id           String   @id @default(cuid())
  bowlerNumber Int      @unique @default(dbgenerated("nextval('bowler_id_seq')"))
  userId       String
  name         String
  age          Int
  highScore    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vouchers  Voucher[]

  @@index([userId])
}

// Family Pass member: age 16+, paid $49.95 to bowl alongside kids.
// Created only after Stripe checkout succeeds.
model Adult {
  id                    String   @id @default(cuid())
  bowlerNumber          Int      @unique @default(dbgenerated("nextval('bowler_id_seq')"))
  userId                String
  name                  String
  age                   Int?
  highScore             Int      @default(0)
  paidAmountCents       Int
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?
  paidAt                DateTime
  programYear           Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vouchers              Voucher[]

  @@index([userId])
  @@index([programYear])
}

// Stash of unpaid adult sign-ups awaiting Stripe checkout completion.
// On checkout.session.completed webhook, we promote these to Adult rows.
// Cleaned up if the session expires.
model PendingAdult {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String   @unique
  name            String
  age             Int?
  programYear     Int
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSessionId])
}

model Voucher {
  id              String    @id @default(cuid())
  userId          String
  childId         String?
  adultId         String?
  validDate       DateTime  @db.Date
  redeemedAt      DateTime?
  redeemedByStaff String?
  gamesBowled     Int?
  createdAt       DateTime  @default(now())

  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  child           Child? @relation(fields: [childId], references: [id], onDelete: Cascade)
  adult           Adult? @relation(fields: [adultId], references: [id], onDelete: Cascade)

  @@unique([childId, validDate])
  @@unique([adultId, validDate])
  @@index([userId, validDate])
  @@index([validDate, redeemedAt])
}

// NextAuth (Auth.js v5) models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
