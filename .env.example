# Database (Neon Postgres — paste both URLs from Neon's Connect tab)
DATABASE_URL="postgresql://user:pass@host-pooler/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Twilio (A2P 10DLC approved sender)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1716XXXXXXX"
TWILIO_MESSAGING_SERVICE_SID=""

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Summer Strikes <summer@manorlanes.com>"

# Stripe (Family Pass — $49.95 per adult 16+)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# App base URL (used to build Stripe checkout return URLs)
NEXT_PUBLIC_APP_URL="https://summer.manorlanes.com"

# Cron secret (used by Vercel Cron to authenticate cron requests)
CRON_SECRET="generate-a-long-random-string"

# Admin email allowlist (comma-separated)
ADMIN_EMAILS="brian@manorlanes.com"

# Conqueror FBT receiver (where new bowlers get POSTed for auto-import)
# Leave blank to disable auto-POST (XML download from /admin/conqueror-export
# still works either way)
FBT_RECEIVER_URL="https://manorlanes.com/lm/summer-strikes-receiver.php"
FBT_RECEIVER_PASSWORD="Manor1974LaneZ"
